{
  "app-id": "com.dejanovic.trashguard",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "trashguard",
  "modules": [
    {
      "name": "trashguard",
      "buildsystem": "simple",
      "build-commands": [
        "install -D src/TrashGuardGui.py /app/bin/trashguard",
        "install -D src/TrashGuard.py /app/bin/TrashGuard.py",
        "install -D src/autostart_handler.py /app/bin/autostart_handler.py",
        "install -D com.dejanovic.trashguard.desktop /app/share/applications/com.dejanovic.trashguard.desktop",
        "install -D com.dejanovic.trashguard.metainfo.xml /app/share/metainfo/com.dejanovic.trashguard.metainfo.xml",
        "install -D src/Slavic_by_nature.svg /app/share/icons/hicolor/scalable/apps/com.dejanovic.trashguard.svg",
        "cp -r locale /app/share/locale"
      ],
      "sources": [
        { "type": "dir", "path": "." }
      ]
    }
  ],
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--filesystem=home",
    "--talk-name=org.freedesktop.portal.Background",
    "--own-name=com.dejanovic.trashguard"
  ]
}
